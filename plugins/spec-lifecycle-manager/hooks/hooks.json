{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write|write_file|create_file)$",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os,runpy,sys;p=sys.argv[1];os.path.isfile(p) and runpy.run_path(p,run_name='__main__')\" \"${PLUGIN_ROOT}/skills/spec-lifecycle-manager/scripts/codex_spec_lifecycle_hook.py\"",
            "timeout": 10,
            "statusMessage": "Checking spec lifecycle advisory feedback"
          }
        ]
      }
    ]
  }
}
