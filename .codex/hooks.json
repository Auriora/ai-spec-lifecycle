{
  "description": "Repository-local Spec Lifecycle Manager development hook.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write|write_file|create_file)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import os,runpy,sys;p=sys.argv[1];os.path.isfile(p) and runpy.run_path(p,run_name='__main__')\" \"$(git rev-parse --show-toplevel)/skills/spec-lifecycle-manager/scripts/codex_spec_lifecycle_hook.py\"",
            "timeout": 10,
            "statusMessage": "Checking repository-local spec lifecycle guidance"
          }
        ]
      }
    ]
  }
}
