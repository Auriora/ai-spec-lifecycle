{
  "name": "spec-lifecycle-manager",
  "version": "0.3.0",
  "registry": "local",
  "distribution": {
    "npm_contract": "packaging/spec-lifecycle-manager/npm-package.json",
    "npm_package": "@auriora/ai-spec-lifecycle",
    "npm_publish_status": "pack-ready-not-published"
  },
  "installer": "packaging/spec-lifecycle-manager/installer.mjs",
  "entrypoint": "plugin-bundled MCP launcher: plugins/spec-lifecycle-manager/mcp-launch.mjs via plugins/spec-lifecycle-manager/.mcp.json",
  "dependency_install": {
    "python": ">=3.10",
    "install_command": "none",
    "runtime_dependencies": [
    "Python 3 standard library"
    ],
    "dev_dependencies": []
  },
  "components": [
    "plugins/spec-lifecycle-manager",
    "plugins/spec-lifecycle-manager/claude-plugin",
    "docs/reference/spec-lifecycle-runtime.md",
    "docs/reference/spec-lifecycle-manager-mcp-install.md",
    "AGENTS.md"
  ],
  "codex": {
    "mcp_server_id": "spec-lifecycle-manager",
    "plugin_manifest": "plugins/spec-lifecycle-manager/.codex-plugin/plugin.json",
    "skill_path": "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager",
    "hook_config_fallback": "packaging/spec-lifecycle-manager/installer.mjs"
  },
  "claude_code": {
    "plugin_root": "plugins/spec-lifecycle-manager/claude-plugin",
    "plugin_manifest": "plugins/spec-lifecycle-manager/claude-plugin/.claude-plugin/plugin.json",
    "plugin_mcp_config": "plugins/spec-lifecycle-manager/claude-plugin/.mcp.json",
    "plugin_skill": "plugins/spec-lifecycle-manager/claude-plugin/skills/spec-lifecycle-manager/SKILL.md",
    "plugin_hooks": "plugins/spec-lifecycle-manager/claude-plugin/hooks/hooks.json",
    "install_model": "Load with claude --plugin-dir plugins/spec-lifecycle-manager/claude-plugin from the unpacked package."
  }
}
