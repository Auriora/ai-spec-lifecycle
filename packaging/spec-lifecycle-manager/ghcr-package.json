{
  "name": "spec-lifecycle-manager",
  "registry": "ghcr.io",
  "image": "ghcr.io/bcherrington/spec-lifecycle-manager",
  "version_source": "plugins/spec-lifecycle-manager/.codex-plugin/plugin.json#/version",
  "publish_status": "contract-ready-not-published",
  "payload_root": "plugins/spec-lifecycle-manager",
  "package_manifest": "packaging/spec-lifecycle-manager/package-manifest.json",
  "containerfile": "packaging/spec-lifecycle-manager/Containerfile",
  "entrypoint": "plugin-bundled mcpServers entry: plugins/spec-lifecycle-manager/.mcp.json",
  "required_paths": [
    "plugins/spec-lifecycle-manager/.codex-plugin/plugin.json",
    "plugins/spec-lifecycle-manager/.mcp.json",
    "plugins/spec-lifecycle-manager/hooks/hooks.json",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/SKILL.md",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/scripts/spec_runtime.py",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/scripts/spec_mcp_server.py",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/scripts/codex_spec_lifecycle_hook.py",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/scripts/traceability_lookup.py",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/prompts",
    "plugins/spec-lifecycle-manager/skills/spec-lifecycle-manager/references",
    "packaging/spec-lifecycle-manager/package-manifest.json",
    "packaging/spec-lifecycle-manager/Containerfile"
  ],
  "compatibility": {
    "python": ">=3.9",
    "codex": "Requires Codex plugin support with skills, plugin-scoped MCP servers, and plugin-scoped hooks.",
    "runtime_dependencies": [
      "Python 3 standard library"
    ]
  },
  "oci_labels": {
    "org.opencontainers.image.title": "Spec Lifecycle Manager",
    "org.opencontainers.image.description": "Codex plugin for spec lifecycle skills, read-only MCP tools, prompts, templates, and advisory hooks.",
    "org.opencontainers.image.source": "https://github.com/bcherrington/agent-dev-lifecycle",
    "org.opencontainers.image.licenses": "MIT"
  },
  "provenance": {
    "source_repository": "https://github.com/bcherrington/agent-dev-lifecycle",
    "source_path": "plugins/spec-lifecycle-manager",
    "commit_source": "git HEAD when packaged",
    "validation_command": "PYTHONDONTWRITEBYTECODE=1 skills/spec-lifecycle-manager/scripts/spec_runtime.py package-contract ."
  },
  "install": {
    "current_supported": "scripts/install-spec-lifecycle-manager-package.sh",
    "ghcr_install": "planned",
    "publish": "planned"
  }
}
